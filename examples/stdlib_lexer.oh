lexer olsun dahil_et "orhun/lexer.oh"

kaynak olsun "işlev ana():\n    yazdır \"Merhaba\"\n"
sonuc olsun lexer.ozetle(kaynak)
tokenlar olsun sonuc.tokenlar

i olsun 0
sürece i küçük uzunluk(tokenlar):
    yazdır tokenlar[i].tur + " " + tokenlar[i].deger
    i olsun i + 1

yazdır lexer.token_araligi(tokenlar[0])
yazdır lexer.lexer_ir_dogrula(sonuc)
