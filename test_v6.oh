# Orhun v0.6 - Standart Kütüphane Testi
yazdır "--- MATEMATİK TESTİ ---"
hipotenus olsun karekok(us(3, 2) + us(4, 2))
yazdır "3-4-5 Üçgeni Hipotenüs: " + hipotenus

yazdır "--- RASTGELE VE ZAMAN ---"
yazdır "Zar atılıyor (2 saniye bekle)..."
bekle(2)
zar olsun rastgele(1, 6)
yazdır "Gelen Zar: " + zar

yazdır "--- METİN İŞLEME ---"
veri olsun "kullanici_id:105,yetki:admin,bolge:tr"
parcalanmis olsun parcala(veri, ",")

yazdır "Ham Veri: " + veri
yazdır "Parçalanmış Liste: " + parcalanmis

yetki_bilgisi olsun parcala(parcalanmis[1], ":")
yazdır "Kullanıcı Yetkisi: " + buyuk_harf(yetki_bilgisi[1])
