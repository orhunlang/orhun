# Orhun v0.7.5 - Metod ve Kutuphane Testi
sayilar olsun [10, 20]
sayilar.ekle(30)
yazdır "Liste Uzunluğu: " + sayilar.uzunluk()
yazdır "Yeni Liste: " + sayilar

notlar olsun { "ali": 90, "veli": 85 }
isimler olsun notlar.anahtarlar()
yazdır "Öğrenci İsimleri: " + isimler

alan olsun matematik.pi * matematik.us(5, 2)
yazdır "Yarıçapı 5 olan daire alanı: " + alan

yazdır "2 saniye bekleniyor..."
zaman.bekle(2)
yazdır "İşlem Tamam."
