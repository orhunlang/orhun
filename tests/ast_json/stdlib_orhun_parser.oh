yazdır json.yaz(islem_ifade_komut_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(islem_ifade_komut_kontrol.komutlar[1].ifade_ozeti)
yazdır json.yaz(islem_ifade_komut_kontrol.komutlar[2].ifade_ozeti)
yazdır json.yaz(islem_ifade_komut_kontrol.komutlar[3].ifade_ozeti)

hata olsun parser.ozetle("@\n")
