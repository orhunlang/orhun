parser olsun dahil_et "orhun/parser.oh"

kaynak olsun "işlev topla(a olsun 1, b olsun 2):\n    döndür a + b\n\nsonuc olsun topla(3)\nyazdır sonuc\n"
sonuc olsun parser.ozetle(kaynak)
lexer_sonucu olsun parser.lexer.ozetle(kaynak)
lexer_gecisi olsun parser.ozetle_lexer_sonucu(lexer_sonucu)
bozuk_lexer_sonucu olsun parser.lexer.ozetle("yazdır 1\n")
bozuk_lexer_sonucu.ir_sozlesmesi = "orhun-lexer-ir-v0"
bozuk_lexer_gecisi olsun parser.ozetle_lexer_sonucu(bozuk_lexer_sonucu)

yazdır parser.surum
yazdır lexer_gecisi.ok
yazdır lexer_gecisi.token_sayisi eşit sonuc.token_sayisi
yazdır bozuk_lexer_gecisi.ok
yazdır metin.icerir(bozuk_lexer_gecisi.hata.mesaj, "Lexer IR gecersiz")
yazdır bozuk_lexer_gecisi.lexer_ir_sozlesmesi
yazdır bozuk_lexer_gecisi.lexer_ir_gecerli
yazdır parser.ir_dogrula(bozuk_lexer_gecisi).ok
yazdır parser.ir_sozlesmesi
yazdır sonuc.ir_sozlesmesi
yazdır sonuc.lexer_ir_sozlesmesi
yazdır sonuc.lexer_ir_gecerli
yazdır parser.ir_uyumlu_mu(sonuc)
yazdır parser.ir_uyumlu_mu({"ir_sozlesmesi": "orhun-parser-ir-v0"})
ir_bilgisi olsun parser.ir_ozeti(sonuc)
yazdır ir_bilgisi.sozlesme
yazdır ir_bilgisi.lexer_sozlesmesi
yazdır ir_bilgisi.lexer_gecerli
yazdır ir_bilgisi.uyumlu
yazdır ir_bilgisi.ust_komut_sayisi
yazdır ir_bilgisi.gecerli
yazdır parser.ir_gecerli_mi(sonuc)
token_gecisi olsun parser.ozetle_tokenlar(parser.lexer.tokenlestir("yazdır 1\n"))
yazdır token_gecisi.ok
yazdır token_gecisi.lexer_ir_gecerli
bozuk_token_gecisi olsun parser.ozetle_tokenlar([parser.lexer.token("KIMLIK", "x", 1, 1)])
yazdır bozuk_token_gecisi.ok
yazdır bozuk_token_gecisi.lexer_ir_gecerli
yazdır parser.ir_dogrula(bozuk_token_gecisi).ok
bozuk_sayi olsun parser.ozetle("yazdır 1\n")
bozuk_sayi["komut_sayisi"] = 2
bozuk_sayi_dogrulamasi olsun parser.ir_dogrula(bozuk_sayi)
yazdır bozuk_sayi_dogrulamasi.ok
yazdır metin.icerir(bozuk_sayi_dogrulamasi.hata, "komut_sayisi")
bozuk_ifade olsun parser.ozetle("yazdır 1\n")
bozuk_ifade.komutlar[0].ifade_ozeti["alt_sayisi"] = 1
bozuk_ifade_dogrulamasi olsun parser.ir_dogrula(bozuk_ifade)
yazdır bozuk_ifade_dogrulamasi.ok
yazdır metin.icerir(bozuk_ifade_dogrulamasi.hata, "alt_sayisi")
yazdır sonuc.ok
yazdır sonuc.hata_sayisi
yazdır sonuc.token_sayisi
yazdır uzunluk(sonuc.komutlar)
yazdır sonuc.komut_sayisi
yazdır metin.birlestir(parser.turleri(sonuc), "|")
yazdır sonuc.komutlar[0].blok_sayisi
yazdır sonuc.komutlar[0].ad
yazdır json.yaz(sonuc.komutlar[0].parametreler)
yazdır json.yaz(sonuc.komutlar[0].varsayilanlar)
yazdır sonuc.komutlar[0].parametre_sayisi
yazdır sonuc.komutlar[0].varsayilan_sayisi
yazdır sonuc.komutlar[1].bildirim
yazdır sonuc.komutlar[1].hedef_ozeti.ayrinti
atama_ifade_araligi olsun parser.ifade_satir_araligi(sonuc.komutlar[1].ifade_ozeti)
yazdır atama_ifade_araligi.baslangic_satir
yazdır atama_ifade_araligi.bitis_satir
yazdır atama_ifade_araligi.satir_sayisi
ifade_araliklari olsun parser.ifade_satir_araliklari(sonuc)
yazdır uzunluk(ifade_araliklari)
yazdır ifade_araliklari[1].baslangic_satir
yazdır ifade_araliklari[1].bitis_satir

coklu olsun parser.ozetle("a, b olsun [1, 2]\nyazdır a\n")
yazdır metin.birlestir(parser.turleri(coklu), "|")
yazdır coklu.komutlar[0].bildirim
yazdır json.yaz(coklu.komutlar[0].hedefler)
yazdır coklu.komutlar[0].hedef_sayisi

esit_kontrol olsun parser.ozetle("sayi = 10\nyazdır sayi\n")
yazdır esit_kontrol.komutlar[0].bildirim
yazdır esit_kontrol.komutlar[0].hedef_ozeti.ayrinti
hedef_aralik_kontrol olsun parser.ozetle("nesne.deger = a + 1\n")
hedef_araliklari olsun parser.tum_ifade_satir_araliklari(hedef_aralik_kontrol)
yazdır uzunluk(hedef_araliklari)
yazdır hedef_araliklari[0].tur + "|" + hedef_araliklari[1].tur + "|" + hedef_araliklari[2].tur + "|" + hedef_araliklari[3].tur + "|" + hedef_araliklari[4].tur

sinif_kontrol olsun parser.ozetle("tip Kedi(Hayvan):\n    yazdır \"miyav\"\n")
yazdır sinif_kontrol.komutlar[0].ad
yazdır sinif_kontrol.komutlar[0].ebeveyn
yazdır sinif_kontrol.komutlar[0].ebeveyn_var

yalin_sinif_kontrol olsun parser.ozetle("tip Kutu:\n    yazdır \"kutu\"\n")
yazdır yalin_sinif_kontrol.komutlar[0].ebeveyn_var

dis_islev_kontrol olsun parser.ozetle("dış_işlev lstrlenA \"kernel32.dll\" (metin: string) -> int\n")
yazdır dis_islev_kontrol.komutlar[0].ad
yazdır dis_islev_kontrol.komutlar[0].kutuphane
yazdır json.yaz(dis_islev_kontrol.komutlar[0].parametre_adlari)
yazdır json.yaz(dis_islev_kontrol.komutlar[0].parametre_tipleri)
yazdır dis_islev_kontrol.komutlar[0].tip_sayisi
yazdır dis_islev_kontrol.komutlar[0].parametre_sayisi
yazdır dis_islev_kontrol.komutlar[0].donus_tipi

dahil_kontrol olsun parser.ozetle("dahil_et \"orhun/temel.oh\"\n")
yazdır dahil_kontrol.komutlar[0].dosya

deneme_kontrol olsun parser.ozetle("deneme:\n    kır\nyakala hata:\n    devam\n")
yazdır deneme_kontrol.komutlar[0].hata_degiskeni
yazdır deneme_kontrol.komutlar[0].blok_sayisi

kontrol olsun parser.ozetle("eğer doğru ise:\n    yazdır \"evet\"\ndeğilse:\n    yazdır \"hayır\"\n")
yazdır kontrol.komutlar[0].blok_sayisi
yazdır json.yaz(kontrol.komutlar[0].blok_sayilari)
yazdır json.yaz(kontrol.komutlar[0].bloklar)
yazdır json.yaz(kontrol.komutlar[0].kosul_ozeti)
tum_araliklar olsun parser.tum_komut_satir_araliklari(kontrol)
yazdır uzunluk(tum_araliklar)
yazdır tum_araliklar[0].satir_sayisi
yazdır tum_araliklar[1].baslangic_satir
yazdır tum_araliklar[2].baslangic_satir
yazdır tum_araliklar[0].tur + "|" + tum_araliklar[1].tur + "|" + tum_araliklar[2].tur
komut_agaci olsun parser.komut_agaci_ozeti(kontrol)
yazdır parser.komut_sayisi(kontrol)
yazdır parser.komut_turu_sayisi(kontrol, "Yazdir")
yazdır parser.komut_turu_var_mi(kontrol, "Eger")
yazdır parser.komut_turu_var_mi(kontrol, "SinifTanim")
yazdır parser.komut_derinligi(kontrol.komutlar[0])
yazdır parser.tum_komut_derinligi(kontrol)
yazdır komut_agaci.komut_sayisi
yazdır komut_agaci.derinlik
yazdır metin.birlestir(komut_agaci.turler, "|")
komut_sayilari olsun parser.komut_tur_sayilari(kontrol)
yazdır komut_sayilari.Eger
yazdır komut_sayilari.Yazdir
yazdır uzunluk(parser.komut_turu_araliklari(kontrol, "Yazdir"))
yazdır uzunluk(parser.komut_turu_araliklari(kontrol, "SinifTanim"))
kontrol_ifade_araliklari olsun parser.tum_ifade_satir_araliklari(kontrol)
yazdır uzunluk(kontrol_ifade_araliklari)
yazdır kontrol_ifade_araliklari[0].tur + "|" + kontrol_ifade_araliklari[1].tur + "|" + kontrol_ifade_araliklari[2].tur

zincir_kontrol olsun parser.ozetle("eğer x büyük 20 ise:\n    yazdır \"buyuk\"\ndeğilse eğer x büyük 5 ise:\n    yazdır \"orta\"\ndeğilse:\n    yazdır \"kucuk\"\n")
yazdır json.yaz(zincir_kontrol.komutlar[0].blok_sayilari)
yazdır json.yaz(zincir_kontrol.komutlar[0].bloklar)

ifade_kontrol olsun parser.ozetle("yazdır a + b * 2\n")
yazdır json.yaz(ifade_kontrol.komutlar[0].ifade_ozeti)
tum_ifade_araliklari olsun parser.tum_ifade_satir_araliklari(ifade_kontrol)
yazdır uzunluk(tum_ifade_araliklari)
yazdır tum_ifade_araliklari[0].tur + "|" + tum_ifade_araliklari[1].tur + "|" + tum_ifade_araliklari[2].tur + "|" + tum_ifade_araliklari[3].tur + "|" + tum_ifade_araliklari[4].tur
yazdır tum_ifade_araliklari[0].baslangic_satir
yazdır tum_ifade_araliklari[0].bitis_satir
ifade_agaci olsun parser.ifade_agaci_ozeti(ifade_kontrol)
yazdır parser.ifade_sayisi(ifade_kontrol)
yazdır parser.ifade_turu_sayisi(ifade_kontrol, "IkiliIslem")
yazdır parser.ifade_turu_var_mi(ifade_kontrol, "Sayi")
yazdır parser.ifade_turu_var_mi(ifade_kontrol, "Metin")
yazdır parser.ifade_derinligi(ifade_kontrol.komutlar[0].ifade_ozeti)
yazdır parser.tum_ifade_derinligi(ifade_kontrol)
yazdır ifade_agaci.ifade_sayisi
yazdır ifade_agaci.derinlik
yazdır metin.birlestir(ifade_agaci.turler, "|")
ifade_sayilari olsun parser.ifade_tur_sayilari(ifade_kontrol)
yazdır ifade_sayilari.IkiliIslem
yazdır ifade_sayilari.Kimlik
yazdır ifade_sayilari.Sayi
yazdır uzunluk(parser.ifade_turu_araliklari(ifade_kontrol, "IkiliIslem"))
yazdır uzunluk(parser.ifade_turu_araliklari(ifade_kontrol, "Metin"))
ifade_ir_indeksi olsun parser.ir_indeksi(ifade_kontrol)
yazdır ifade_ir_indeksi.gecerli
yazdır ifade_ir_indeksi.ifade_tur_sayilari.IkiliIslem
yazdır ifade_ir_indeksi.komut_tur_sayilari.Yazdir
yazdır uzunluk(ifade_ir_indeksi.ifade_araliklari)
yazdır uzunluk(ifade_ir_indeksi.komut_araliklari)

koleksiyon_kontrol olsun parser.ozetle("liste olsun [1, 2, 3]\nyazdır [x * 2 için x içinde liste eğer x büyük 1]\n")
yazdır json.yaz(koleksiyon_kontrol.komutlar[0].ifade_ozeti.altlar)
yazdır koleksiyon_kontrol.komutlar[0].ifade_ozeti.oge_sayisi
yazdır json.yaz(koleksiyon_kontrol.komutlar[1].ifade_ozeti.altlar)
yazdır koleksiyon_kontrol.komutlar[1].ifade_ozeti.degisken
yazdır koleksiyon_kontrol.komutlar[1].ifade_ozeti.kosul_var

kosulsuz_uretec_kontrol olsun parser.ozetle("yazdır [x için x içinde liste]\n")
yazdır kosulsuz_uretec_kontrol.komutlar[0].ifade_ozeti.kosul_var

sozluk_kontrol olsun parser.ozetle("ayar olsun {\"ad\": \"orhun\", \"surum\": 1}\n")
yazdır json.yaz(sozluk_kontrol.komutlar[0].ifade_ozeti.anahtarlar)
yazdır sozluk_kontrol.komutlar[0].ifade_ozeti.oge_sayisi

erisim_kontrol olsun parser.ozetle("ilk olsun liste[0]\nad olsun sozluk?.ad\nnesne olsun yeni Kutu(3)\n")
yazdır json.yaz(erisim_kontrol.komutlar[0].ifade_ozeti.altlar)
yazdır json.yaz(erisim_kontrol.komutlar[1].ifade_ozeti.altlar)
yazdır json.yaz(erisim_kontrol.komutlar[2].ifade_ozeti.altlar)

literal_postfix_kontrol olsun parser.ozetle("ilk olsun [1, 2][0]\nad olsun {\"ad\": \"orhun\"}.ad\n")
yazdır json.yaz(literal_postfix_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(literal_postfix_kontrol.komutlar[1].ifade_ozeti)

dilim_kontrol olsun parser.ozetle("parca olsun liste[1:3]\nbaslar olsun liste[:2]\nsonlar olsun liste[1:]\n")
yazdır json.yaz(dilim_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(dilim_kontrol.komutlar[1].ifade_ozeti)
yazdır json.yaz(dilim_kontrol.komutlar[2].ifade_ozeti)

alan_kontrol olsun parser.ozetle("alan olsun nesne.deger\nokuma olsun nesne.oku()\n")
yazdır json.yaz(alan_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(alan_kontrol.komutlar[1].ifade_ozeti)

ozel_alan_kontrol olsun parser.ozetle("benimalan olsun benim.deger\nbenimokuma olsun benim.oku()\nustalan olsun ust.kur\nustokuma olsun ust.kur(1)\n")
yazdır json.yaz(ozel_alan_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(ozel_alan_kontrol.komutlar[1].ifade_ozeti)
yazdır json.yaz(ozel_alan_kontrol.komutlar[2].ifade_ozeti)
yazdır json.yaz(ozel_alan_kontrol.komutlar[3].ifade_ozeti)

cagri_kontrol olsun parser.ozetle("sonuc olsun topla(4, a + 1)\nikiyle olsun işlev(x): x * 2\n")
yazdır json.yaz(cagri_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(cagri_kontrol.komutlar[1].ifade_ozeti)

lambda_param_kontrol olsun parser.ozetle("f olsun işlev(a, b olsun 2): a + b\n")
yazdır json.yaz(lambda_param_kontrol.komutlar[0].ifade_ozeti)
lambda_ifade_araliklari olsun parser.tum_ifade_satir_araliklari(lambda_param_kontrol)
yazdır uzunluk(lambda_ifade_araliklari)
yazdır lambda_ifade_araliklari[0].tur + "|" + lambda_ifade_araliklari[1].tur + "|" + lambda_ifade_araliklari[2].tur + "|" + lambda_ifade_araliklari[3].tur + "|" + lambda_ifade_araliklari[4].tur + "|" + lambda_ifade_araliklari[5].tur

islev_aralik_kontrol olsun parser.ozetle("işlev topla(a, b olsun 2):\n    döndür a + b\n")
islev_ifade_araliklari olsun parser.tum_ifade_satir_araliklari(islev_aralik_kontrol)
yazdır uzunluk(islev_ifade_araliklari)
yazdır islev_ifade_araliklari[0].tur + "|" + islev_ifade_araliklari[1].tur + "|" + islev_ifade_araliklari[2].tur + "|" + islev_ifade_araliklari[3].tur

tekli_kontrol olsun parser.ozetle("negatif olsun -5\nters olsun değil yanlış\n")
yazdır json.yaz(tekli_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(tekli_kontrol.komutlar[1].ifade_ozeti)

paralel_kontrol olsun parser.ozetle("gorev olsun paralel yap: yazdır \"sur\"\n")
yazdır json.yaz(paralel_kontrol.komutlar[0].ifade_ozeti)
paralel_ifade_araliklari olsun parser.tum_ifade_satir_araliklari(paralel_kontrol)
yazdır uzunluk(paralel_ifade_araliklari)
yazdır paralel_ifade_araliklari[0].tur + "|" + paralel_ifade_araliklari[1].tur + "|" + paralel_ifade_araliklari[2].tur
paralel_komut_araliklari olsun parser.tum_komut_satir_araliklari(paralel_kontrol)
yazdır uzunluk(paralel_komut_araliklari)
yazdır paralel_komut_araliklari[0].tur + "|" + paralel_komut_araliklari[1].tur
yazdır parser.tum_komut_derinligi(paralel_kontrol)

ozel_ifade_kontrol olsun parser.ozetle("yanit olsun sor \"Ad?\"\ntemel olsun dahil_et \"orhun/temel.oh\"\n")
yazdır json.yaz(ozel_ifade_kontrol.komutlar[0].ifade_ozeti)
yazdır json.yaz(ozel_ifade_kontrol.komutlar[1].ifade_ozeti)

ifade_komut_kontrol olsun parser.ozetle("sor \"Ad?\"\ndoğru\ndeğil yanlış\nyeni Kutu(1)\nbenim.deger\nust.kur\nparalel yap: yazdır \"sur\"\n")
