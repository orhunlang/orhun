koleksiyon olsun dahil_et "orhun/koleksiyon.oh"

yazdır koleksiyon.surum
yazdır koleksiyon.icerir([1, 2, 3], 2)
yazdır koleksiyon.icerir([1, 2, 3], 9)
yazdır koleksiyon.say([1, 2, 1, 3, 1], 1)

cift_mi olsun işlev(x): x % 2 eşit 0
buyuk_mu olsun işlev(x): x büyük 3
topla olsun işlev(toplam, x): toplam + x
kare olsun işlev(x): x * x

yazdır koleksiyon.bul([1, 3, 4, 6], cift_mi, 0)
yazdır koleksiyon.bul([1, 3, 5], cift_mi, 99)
yazdır koleksiyon.hepsi([2, 4, 6], cift_mi)
yazdır koleksiyon.hepsi([2, 3, 6], cift_mi)
yazdır koleksiyon.herhangi([1, 3, 4], buyuk_mu)
yazdır koleksiyon.herhangi([1, 2, 3], buyuk_mu)
yazdır koleksiyon.katla([1, 2, 3, 4], 0, topla)
yazdır koleksiyon.toplam([1, 2, 3, 4])
yazdır koleksiyon.toplam([1, 2, 3], 10)
yazdır koleksiyon.en_kucuk([5, -2, 8, 1], 99)
yazdır koleksiyon.en_küçük([], 99)
yazdır koleksiyon.en_buyuk([5, -2, 8, 1], 99)
yazdır koleksiyon.en_büyük([], 99)
yazdır koleksiyon.haritala([1, 2, 3], kare)
yazdır koleksiyon.filtrele([1, 2, 3, 4, 5], cift_mi)
yazdır koleksiyon.ters([1, 2, 3])
yazdır koleksiyon.benzersiz([1, 2, 1, 3, 2])
yazdır koleksiyon.ilk([4, 5], 0)
yazdır koleksiyon.ilk([], 0)
yazdır koleksiyon.son([4, 5], 0)
yazdır koleksiyon.son([], 0)
yazdır koleksiyon.indeks([1, 2, 1], 1)
yazdır koleksiyon.indeks([1, 2, 1], 9)
yazdır koleksiyon.al([1, 2, 3, 4], 2)
yazdır koleksiyon.al([1, 2, 3, 4], 9)
yazdır koleksiyon.atla([1, 2, 3, 4], 2)
yazdır koleksiyon.atla([1, 2], -2)
yazdır koleksiyon.parcalara_ayir([1, 2, 3, 4, 5], 2)
yazdır koleksiyon.parçalara_ayır([1, 2], 0)
yazdır koleksiyon.duzlestir([[1, 2], [], [3]])
yazdır koleksiyon.düzleştir([[4], [5, 6]])
yazdır koleksiyon.birlesim([1, 2, 1], [2, 3])
yazdır koleksiyon.birleşim([], [4, 4, 5])
yazdır koleksiyon.kesisim([1, 2, 2, 3], [2, 3, 4])
yazdır koleksiyon.kesişim([1, 2], [3, 4])
yazdır koleksiyon.fark([1, 2, 2, 3], [2])
yazdır koleksiyon.sirala([3, -1, 2, 2])
yazdır koleksiyon.sırala([])
