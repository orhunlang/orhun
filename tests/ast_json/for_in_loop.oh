# ast: Atama,HerDongu,Atama,Atama,HerDongu,Yazdir,Atama,HerDongu,Yazdir
meyveler olsun ["elma", "armut", "kiraz"]
her meyve içinde meyveler:
    yazdır meyve

toplam olsun 0
sayilar olsun [10, 20, 30]
her sayi içinde sayilar:
    eğer sayi eşit 20 ise:
        devam
    toplam = toplam + sayi
yazdır toplam

sayac olsun 0
her sayi içinde sayilar:
    sayac = sayac + 1
    eğer sayac eşit 2 ise:
        kır
yazdır sayac
