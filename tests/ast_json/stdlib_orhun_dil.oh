dil olsun dahil_et "orhun/dil.oh"

işlev sayi_oku(imlec):
    sonuc olsun dil.bekle(imlec, "SAYI", "", "sayi bekleniyor")
    eğer sonuc.ok ise:
        döndür dil.yaprak("Sayi", sonuc.deger.deger, sonuc.deger)
    döndür dil.dugum("Hata", sonuc.hata, [], 0, 0)

tokenlar olsun [
    dil.token("SAYI", "2", 1, 1),
    dil.token("ARTI", "+", 1, 3),
    dil.token("SAYI", "3", 1, 5),
    dil.dosya_sonu(1, 6),
]

imlec olsun dil.imlec(tokenlar)
sol olsun sayi_oku(imlec)
arti olsun dil.bekle(imlec, "ARTI", "+", "arti bekleniyor")
sag olsun sayi_oku(imlec)
ast olsun dil.program([dil.dugum("Topla", arti.deger.deger, [sol, sag], 1, 3)])

yazdır dil.surum
yazdır dil.dugum_sayisi(ast)
yazdır metin.birlestir(dil.dugum_turleri(ast.cocuklar), "|")
