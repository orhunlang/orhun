deger olsun 10
paylasilan olsun [10]
dongu_degeri olsun ""

her oge içinde ["modul-dongu"]:
    dongu_degeri = oge

işlev topla(a, b):
    döndür a + b

işlev iki_kat(x):
    döndür x * 2

işlev hesapla(x):
    döndür iki_kat(x) + paylasilan[0]

tip Kutu:
    sayi olsun 0
    işlev kur(v):
        benim.sayi olsun v
