paket_yardimci olsun dahil_et "orhun/paket.oh"

manifest_metin olsun "{\"ad\":\"ornek\",\"surum\":\"0.1.0\",\"giris\":\"ana.oh\",\"bagimliliklar\":[\"temel\",\"sonuc\"]}"
cozum olsun paket_yardimci.coz(manifest_metin)
manifest olsun cozum.deger

yazdır paket_yardimci.surum
yazdır cozum.ok
yazdır paket_yardimci.ad(manifest)
yazdır paket_yardimci.surum_al(manifest)
yazdır paket_yardimci.giris(manifest)
yazdır paket_yardimci.ozet(manifest)
yazdır paket_yardimci.bagimli_mi(manifest, "sonuc")
yazdır paket_yardimci.bagimli_mi(manifest, "metin")
yazdır paket_yardimci.dogrula(manifest).ok
yazdır paket_yardimci.ad_gecerli_mi("ornek_paket-1.0")
yazdır paket_yardimci.ad_gecerli_mi("kotu/ad")
yazdır paket_yardimci.ad_gecerli_mi(".")
yazdır paket_yardimci.ad_gecerli_mi("..")
yazdır paket_yardimci.surum_gecerli_mi("1.2.3")
yazdır paket_yardimci.surum_gecerli_mi("1.2.3-alpha.1+build.5")
yazdır paket_yardimci.surum_gecerli_mi("01.2.3")
yazdır paket_yardimci.surum_gecerli_mi("1.2")
yazdır paket_yardimci.surum_gecerli_mi("1.2.3-alpha.01")

ayristirilmis olsun paket_yardimci.surum_ayristir("1.2.3-alpha.1+build.5")
yazdır ayristirilmis.ok
yazdır ayristirilmis.deger.ana
yazdır ayristirilmis.deger.yan
yazdır ayristirilmis.deger.duzeltme
yazdır ayristirilmis.deger.on_surum
yazdır ayristirilmis.deger.yapi
yazdır paket_yardimci.surum_ayristir("1.2.3").deger.on_surum eşit ""
yazdır paket_yardimci.surum_ayristir("1.2").ok

varsayilanli olsun json.coz("{\"ad\":\"yalin\",\"surum\":\"1.0.0\"}")
yazdır paket_yardimci.giris(varsayilanli)
yazdır uzunluk(paket_yardimci.bagimliliklar(varsayilanli))
yazdır paket_yardimci.coz_ve_dogrula(json.yaz(varsayilanli)).ok

eksik olsun json.coz("{\"ad\":\"eksik\"}")
yazdır paket_yardimci.dogrula(eksik).ok
yazdır metin.icerir(paket_yardimci.dogrula(eksik).hata, "surum")

gecersiz_surum olsun json.coz("{\"ad\":\"ornek\",\"surum\":\"son\"}")
yazdır paket_yardimci.dogrula(gecersiz_surum).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_surum).hata, "semantik")

yanlis_bagimlilik olsun json.coz("{\"ad\":\"yanlis\",\"surum\":\"1.0.0\",\"bagimliliklar\":\"temel\"}")
yazdır paket_yardimci.dogrula(yanlis_bagimlilik).ok
yazdır metin.icerir(paket_yardimci.dogrula(yanlis_bagimlilik).hata, "liste")

gecersiz_ad olsun json.coz("{\"ad\":\"kotu/ad\",\"surum\":\"1.0.0\"}")
yazdır paket_yardimci.dogrula(gecersiz_ad).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_ad).hata, "ad")

gecersiz_bagimlilik olsun json.coz("{\"ad\":\"ornek\",\"surum\":\"1.0.0\",\"bagimliliklar\":[\"temel\",\"kotu/ad\"]}")
yazdır paket_yardimci.dogrula(gecersiz_bagimlilik).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_bagimlilik).hata, "bagimlilik")

gecersiz_ad_tipi olsun json.coz("{\"ad\":1,\"surum\":\"1.0.0\"}")
yazdır paket_yardimci.dogrula(gecersiz_ad_tipi).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_ad_tipi).hata, "ad")

gecersiz_bagimlilik_tipi olsun json.coz("{\"ad\":\"ornek\",\"surum\":\"1.0.0\",\"bagimliliklar\":[1]}")
yazdır paket_yardimci.dogrula(gecersiz_bagimlilik_tipi).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_bagimlilik_tipi).hata, "bagimlilik")

bozuk olsun paket_yardimci.coz("{bozuk")
yazdır bozuk.ok
yazdır metin.icerir(bozuk.hata, "json.coz")
