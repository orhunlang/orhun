paket_yardimci olsun dahil_et "orhun/paket.oh"

manifest_metin olsun "{\"ad\":\"ornek\",\"surum\":\"0.1.0\",\"giris\":\"ana.oh\",\"bagimliliklar\":[\"temel\",\"sonuc\"]}"
cozum olsun paket_yardimci.coz(manifest_metin)
manifest olsun cozum.deger

yazdır paket_yardimci.surum
yazdır cozum.ok
yazdır paket_yardimci.ad(manifest)
yazdır paket_yardimci.surum_al(manifest)
yazdır paket_yardimci.giris(manifest)
yazdır paket_yardimci.ozet(manifest)
yazdır paket_yardimci.bagimli_mi(manifest, "sonuc")
yazdır paket_yardimci.bagimli_mi(manifest, "metin")
yazdır paket_yardimci.dogrula(manifest).ok
yazdır paket_yardimci.ad_gecerli_mi("ornek_paket-1.0")
yazdır paket_yardimci.ad_gecerli_mi("kotu/ad")
yazdır paket_yardimci.ad_gecerli_mi(".")
yazdır paket_yardimci.ad_gecerli_mi("..")
yazdır paket_yardimci.surum_gecerli_mi("1.2.3")
yazdır paket_yardimci.surum_gecerli_mi("1.2.3-alpha.1+build.5")
yazdır paket_yardimci.surum_gecerli_mi("01.2.3")
yazdır paket_yardimci.surum_gecerli_mi("1.2")
yazdır paket_yardimci.surum_gecerli_mi("1.2.3-alpha.01")

ayristirilmis olsun paket_yardimci.surum_ayristir("1.2.3-alpha.1+build.5")
yazdır ayristirilmis.ok
yazdır ayristirilmis.deger.ana
yazdır ayristirilmis.deger.yan
yazdır ayristirilmis.deger.duzeltme
yazdır ayristirilmis.deger.on_surum
yazdır ayristirilmis.deger.yapi
yazdır paket_yardimci.surum_ayristir("1.2.3").deger.on_surum eşit ""
yazdır paket_yardimci.surum_ayristir("1.2").ok

karsilastirma olsun paket_yardimci.surum_karsilastir("1.2.3-alpha.1", "1.2.3-alpha.beta")
yazdır karsilastirma.ok
yazdır paket_yardimci.surum_karsilastir("1.2.3", "1.2.4").deger
yazdır paket_yardimci.surum_karsilastir("2.0.0", "1.99.99").deger
yazdır paket_yardimci.surum_karsilastir("1.0.0-alpha", "1.0.0-alpha.1").deger
yazdır karsilastirma.deger
yazdır paket_yardimci.surum_karsilastir("1.0.0-alpha.beta", "1.0.0-beta").deger
yazdır paket_yardimci.surum_karsilastir("1.0.0-beta", "1.0.0-beta.2").deger
yazdır paket_yardimci.surum_karsilastir("1.0.0-beta.2", "1.0.0-beta.11").deger
yazdır paket_yardimci.surum_karsilastir("1.0.0-rc.1", "1.0.0").deger
yazdır paket_yardimci.surum_karsilastir("1.0.0+build.1", "1.0.0+build.2").deger
yazdır paket_yardimci.surum_karsilastir("1.2", "1.2.3").ok

yazdır paket_yardimci.surum_uyumlu_mu("1.2.3", "*").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.2.3", "1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.2.4", "1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.3.0", ">=1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.2.2", ">=1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.2.3", "<1.2.4").deger
yazdır paket_yardimci.surum_uyumlu_mu("2.0.0", "^1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.9.9", "^1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("0.3.0", "^0.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("0.2.9", "^0.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("0.0.4", "^0.0.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.3.0", "~1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.2.9", "~1.2.3").deger
yazdır paket_yardimci.surum_uyumlu_mu("1.2.3", "^1.2").ok

istek olsun paket_yardimci.bagimlilik_istegi("ag", "^1.2.0")
adaylar olsun [{"ad":"ag","surum":"1.1.9"}, {"ad":"ag","surum":"1.2.1"}, {"ad":"ag","surum":"1.8.0"}, {"ad":"ag","surum":"2.0.0"}, {"ad":"veri","surum":"9.0.0"}]
secim olsun paket_yardimci.en_uygun_bagimlilik(istek, adaylar)
yazdır secim.ok
yazdır secim.deger.surum
yazdır paket_yardimci.en_uygun_bagimlilik(paket_yardimci.bagimlilik_istegi("ag", "~1.2.0"), adaylar).deger.surum
uyumsuz_secim olsun paket_yardimci.en_uygun_bagimlilik(paket_yardimci.bagimlilik_istegi("ag", "^3.0.0"), adaylar)
yazdır uyumsuz_secim.ok
yazdır metin.icerir(uyumsuz_secim.hata, "uygun")
yazdır metin.icerir(uyumsuz_secim.hata, "bulunan")
yazdır metin.icerir(uyumsuz_secim.hata, "1.8.0")
yazdır metin.birlestir(paket_yardimci.bagimlilik_aday_surimleri(istek, adaylar).deger, "|")
eksik_secim olsun paket_yardimci.en_uygun_bagimlilik(paket_yardimci.bagimlilik_istegi("yok", "^1.0.0"), adaylar)
yazdır eksik_secim.ok
yazdır metin.icerir(eksik_secim.hata, "adayi")
yazdır paket_yardimci.en_uygun_bagimlilik(paket_yardimci.bagimlilik_istegi("ag", "^1.2"), adaylar).ok
secilenler olsun paket_yardimci.bagimlilikleri_sec([istek, paket_yardimci.bagimlilik_istegi("veri", "*")], adaylar)
yazdır secilenler.ok
yazdır secilenler.deger[0].surum
yazdır secilenler.deger[1].surum
yazdır paket_yardimci.bagimlilikleri_sec([istek, istek], adaylar).ok

surumlu_manifest olsun json.coz("{\"ad\":\"uygulama\",\"surum\":\"1.0.0\",\"bagimliliklar\":[\"ag\"],\"bagimlilik_istekleri\":[{\"ad\":\"ag\",\"kural\":\"^1.2.0\"}]}")
yazdır paket_yardimci.dogrula(surumlu_manifest).ok
yazdır paket_yardimci.bagimlilik_istekleri(surumlu_manifest)[0].kural
uyusmayan_istek_manifest olsun json.coz("{\"ad\":\"uygulama\",\"surum\":\"1.0.0\",\"bagimlilik_istekleri\":[{\"ad\":\"ag\",\"kural\":\"^1.2.0\"}]}")
yazdır paket_yardimci.dogrula(uyusmayan_istek_manifest).ok
yazdır metin.icerir(paket_yardimci.dogrula(uyusmayan_istek_manifest).hata, "listede")
gecersiz_istek_manifest olsun json.coz("{\"ad\":\"uygulama\",\"surum\":\"1.0.0\",\"bagimliliklar\":[\"ag\"],\"bagimlilik_istekleri\":[{\"ad\":\"ag\",\"kural\":\"^1.2\"}]}")
yazdır paket_yardimci.dogrula(gecersiz_istek_manifest).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_istek_manifest).hata, "istegi")

cozum_manifesti olsun json.coz("{\"ad\":\"uygulama\",\"surum\":\"1.0.0\",\"bagimliliklar\":[\"ag\",\"veri\"],\"bagimlilik_istekleri\":[{\"ad\":\"ag\",\"kural\":\"^1.2.0\"}]}")
manifest_secimi olsun paket_yardimci.manifest_bagimliliklarini_sec(cozum_manifesti, adaylar)
yazdır manifest_secimi.ok
yazdır manifest_secimi.deger[0].surum
yazdır manifest_secimi.deger[1].surum
yazdır paket_yardimci.manifest_bagimlilik_istekleri(cozum_manifesti)[1].kural

v3_satiri olsun "deneme|https://github.com/orhunlang/deneme.git|ozet|v3|abc1234|icerik|v1.0.0"
kilit_cozumu olsun paket_yardimci.kilit_satirini_coz(v3_satiri)
yazdır kilit_cozumu.ok
yazdır kilit_cozumu.deger.kayit.ad
yazdır kilit_cozumu.deger.kayit.kaynak_ref
yazdır paket_yardimci.kilit_satirini_coz("eski|yerel|crc").deger.kayit.surum
yazdır paket_yardimci.kilit_satirini_coz("v2|yerel|hash|v2").deger.kayit.surum
yazdır paket_yardimci.kilit_satirini_coz("v3|yerel|hash|v3").ok
yazdır metin.icerir(paket_yardimci.kilit_satirini_coz("v3|yerel|hash|v3").hata, "commit")
yazdır paket_yardimci.kilit_satirini_coz("..|yerel|hash|v2").ok
yazdır paket_yardimci.kaynak_ref_gecerli_mi("refs/tags/v1.0.0")
yazdır paket_yardimci.kaynak_ref_gecerli_mi("kotu ref")
yazdır paket_yardimci.kaynak_ref_gecerli_mi("kotu|ref")

kilit_dosyasi olsun "# kilit\n\ndeneme|yerel|hash|v2\n" + v3_satiri
kilit_listesi olsun paket_yardimci.kilit_dosyasini_coz(kilit_dosyasi)
yazdır kilit_listesi.ok
yazdır uzunluk(kilit_listesi.deger)
yazdır paket_yardimci.kilit_dosyasi_metni(kilit_listesi.deger).ok
yazdır metin.icerir(paket_yardimci.kilit_dosyasi_metni(kilit_listesi.deger).deger, "source_ref")
yazdır metin.icerir(paket_yardimci.kilit_dosyasi_metni(kilit_listesi.deger).deger, v3_satiri)

manifestler olsun [
    {"ad":"uygulama","surum":"1.0.0","bagimliliklar":["ag","veri"]},
    {"ad":"ag","surum":"1.0.0","bagimliliklar":["temel"]},
    {"ad":"veri","surum":"1.0.0","bagimliliklar":["temel"]},
    {"ad":"temel","surum":"1.0.0"}
]
plan olsun paket_yardimci.bagimlilik_plani(manifestler)
yazdır plan.ok
yazdır plan.deger[0]
yazdır plan.deger[1]
yazdır plan.deger[2]
yazdır plan.deger[3]

eksik_plan olsun paket_yardimci.bagimlilik_plani([{"ad":"a","surum":"1.0.0","bagimliliklar":["yok"]}])
yazdır eksik_plan.ok
yazdır metin.icerir(eksik_plan.hata, "bulunamadi")

dongu_plan olsun paket_yardimci.bagimlilik_plani([{"ad":"a","surum":"1.0.0","bagimliliklar":["b"]}, {"ad":"b","surum":"1.0.0","bagimliliklar":["a"]}])
yazdır dongu_plan.ok
yazdır metin.icerir(dongu_plan.hata, "dongu")

tekrar_plan olsun paket_yardimci.bagimlilik_plani([{"ad":"a","surum":"1.0.0"}, {"ad":"a","surum":"1.0.0"}])
yazdır tekrar_plan.ok
yazdır metin.icerir(tekrar_plan.hata, "tekrar")

varsayilanli olsun json.coz("{\"ad\":\"yalin\",\"surum\":\"1.0.0\"}")
yazdır paket_yardimci.giris(varsayilanli)
yazdır uzunluk(paket_yardimci.bagimliliklar(varsayilanli))
yazdır paket_yardimci.coz_ve_dogrula(json.yaz(varsayilanli)).ok

eksik olsun json.coz("{\"ad\":\"eksik\"}")
yazdır paket_yardimci.dogrula(eksik).ok
yazdır metin.icerir(paket_yardimci.dogrula(eksik).hata, "surum")

gecersiz_surum olsun json.coz("{\"ad\":\"ornek\",\"surum\":\"son\"}")
yazdır paket_yardimci.dogrula(gecersiz_surum).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_surum).hata, "semantik")

yanlis_bagimlilik olsun json.coz("{\"ad\":\"yanlis\",\"surum\":\"1.0.0\",\"bagimliliklar\":\"temel\"}")
yazdır paket_yardimci.dogrula(yanlis_bagimlilik).ok
yazdır metin.icerir(paket_yardimci.dogrula(yanlis_bagimlilik).hata, "liste")

gecersiz_ad olsun json.coz("{\"ad\":\"kotu/ad\",\"surum\":\"1.0.0\"}")
yazdır paket_yardimci.dogrula(gecersiz_ad).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_ad).hata, "ad")

gecersiz_bagimlilik olsun json.coz("{\"ad\":\"ornek\",\"surum\":\"1.0.0\",\"bagimliliklar\":[\"temel\",\"kotu/ad\"]}")
yazdır paket_yardimci.dogrula(gecersiz_bagimlilik).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_bagimlilik).hata, "bagimlilik")

gecersiz_ad_tipi olsun json.coz("{\"ad\":1,\"surum\":\"1.0.0\"}")
yazdır paket_yardimci.dogrula(gecersiz_ad_tipi).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_ad_tipi).hata, "ad")

gecersiz_bagimlilik_tipi olsun json.coz("{\"ad\":\"ornek\",\"surum\":\"1.0.0\",\"bagimliliklar\":[1]}")
yazdır paket_yardimci.dogrula(gecersiz_bagimlilik_tipi).ok
yazdır metin.icerir(paket_yardimci.dogrula(gecersiz_bagimlilik_tipi).hata, "bagimlilik")

bozuk olsun paket_yardimci.coz("{bozuk")
yazdır bozuk.ok
yazdır metin.icerir(bozuk.hata, "json.coz")
