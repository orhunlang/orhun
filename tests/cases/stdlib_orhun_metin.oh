metin_yardimci olsun dahil_et "orhun/metin.oh"

yazdır metin_yardimci.surum
yazdır metin_yardimci.bos_mu("")
yazdır metin_yardimci.dolu_mu("orhun")
yazdır metin_yardimci.baslar_mi("orhun dili", "orhun")
yazdır metin_yardimci.baslar_mi("orhun dili", "dil")
yazdır metin_yardimci.biter_mi("orhun dili", "dili")
yazdır metin_yardimci.biter_mi("orhun dili", "orhun")
yazdır metin_yardimci.ters("abc")
yazdır metin_yardimci.tekrar("ha", 3)
yazdır metin_yardimci.degistir("orhun dili dili", "dili", "gucu")
yazdır metin_yardimci.icerir("orhun dili", "hun")
yazdır metin_yardimci.icerir("orhun dili", "java")
yazdır metin_yardimci.say("orhun orhun", "orhun")
yazdır metin_yardimci.say("aaaa", "aa")
yazdır metin_yardimci.say("orhun", "")
yazdır metin_yardimci.on_eki_kaldir("orhun-dili", "orhun-")
yazdır metin_yardimci.ön_eki_kaldır("orhun-dili", "dil-")
yazdır metin_yardimci.son_eki_kaldir("orhun.oh", ".oh")
yazdır metin_yardimci.son_eki_kaldır("orhun.oh", "")
yazdır metin_yardimci.satirlara_ayir("a\nb")[1]
yazdır metin_yardimci.kelimelere_ayir("orhun dili")[0]
satir_donusu olsun json.coz("\"\\r\"")
yazdır metin_yardimci.bosluk_mu(satir_donusu)
yazdır metin_yardimci.bosluk_mu("r")
yazdır "[" + metin_yardimci.sol_kirp("  orhun ") + "]"
yazdır "[" + metin_yardimci.sag_kirp("  orhun ") + "]"
yazdır "[" + metin_yardimci.kirp("  orhun ") + "]"
yazdır metin_yardimci.ilk_konum("orhun dili", "hun")
yazdır metin_yardimci.ilk_konum("orhun dili", "java", 99)
yazdır metin_yardimci.son_konum("ababa", "ba")
yazdır metin_yardimci.sol_doldur("7", 3, "0")
yazdır metin_yardimci.sag_doldur("7", 3, "0")
yazdır metin_yardimci.sağ_doldur("x", 4, "ab")
yazdır metin_yardimci.ortala("x", 5, "-")
