# '=' atamasi islev icinde mevcut baglami gunceller
x olsun 1

işlev global_degistir():
    x = 5
    döndür 0

global_degistir()
yazdır x

işlev yerel_degistir():
    y olsun 10
    y = y + 10
    döndür y

yazdır yerel_degistir()

# 'olsun', döngü bloğında mevcut işlev yerelini günceller.
işlev yerel_dongu():
    i olsun 0
    toplam olsun 0
    sürece i küçük 3:
        toplam olsun toplam + i
        i olsun i + 1
    döndür toplam

yazdır yerel_dongu()

# Cagrilan islevdeki bildirim, cagiranin ayni adli yerelini degistirmez.
işlev ic_bildirim():
    token olsun "ic"
    döndür token

işlev dis_bildirim():
    token olsun "dis"
    ic_bildirim()
    döndür token

yazdır dis_bildirim()
