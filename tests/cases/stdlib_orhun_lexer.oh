lexer olsun dahil_et "orhun/lexer.oh"

kaynak olsun "işlev ana():\n    puan olsun 10.5\n    yazdır \"merhaba\"\n"
sonuc olsun lexer.ozetle(kaynak)
tokenlar olsun sonuc.tokenlar

yazdır lexer.surum
yazdır sonuc.ir_sozlesmesi
yazdır lexer.ir_sozlesmesi
yazdır lexer.ir_uyumlu_mu(sonuc)
yazdır lexer.ir_gecerli_mi(sonuc)
yazdır lexer.ir_dogrula(sonuc).ok
ir_ozeti olsun lexer.ir_ozeti(sonuc)
yazdır ir_ozeti.sozlesme
yazdır ir_ozeti.gecerli
yazdır sonuc.hata_sayisi
yazdır sonuc.token_sayisi
yazdır uzunluk(tokenlar)
yazdır metin.birlestir(lexer.turleri(tokenlar), "|")
yazdır json.yaz(lexer.degerleri(tokenlar))
yazdır tokenlar[0].tur + ":" + tokenlar[0].deger
yazdır tokenlar[7].tur + ":" + tokenlar[7].deger
yazdır tokenlar[9].tur + ":" + tokenlar[9].deger
yazdır tokenlar[12].tur + ":" + tokenlar[12].deger
yazdır tokenlar[14].tur + ":" + tokenlar[14].deger

yorumlu olsun lexer.tokenlestir("# yorum\nx olsun 1\n")
yazdır yorumlu[0].tur + ":" + yorumlu[0].deger
yazdır yorumlu[1].tur + ":" + yorumlu[1].deger

satir_donusu olsun json.coz("\"\\r\"")
crlf_kaynak olsun "a olsun 1" + satir_donusu + "\nb olsun 2" + satir_donusu + "\n"
crlf olsun lexer.tokenlestir(crlf_kaynak)
yazdır uzunluk(crlf)
yazdır metin.birlestir(lexer.turleri(crlf), "|")
yazdır crlf[3].tur + ":" + crlf[3].deger
yazdır crlf[4].tur + ":" + crlf[4].deger

girinti_hata olsun lexer.tokenlestir("eğer doğru ise:\n  yazdır 1\n yazdır 2\n")
yazdır lexer.hata_var_mi(girinti_hata)
yazdır lexer.hata_sayisi(girinti_hata)
yazdır metin.icerir(lexer.ilk_hata(girinti_hata).deger, "girinti")
yazdır json.yaz(lexer.hata_degerleri(girinti_hata))

metin_hata olsun lexer.ozetle("yazdır \"acik\n")
yazdır metin_hata.hata_sayisi
yazdır metin_hata.token_sayisi
yazdır lexer.hata_var_mi(metin_hata.tokenlar)
yazdır metin.icerir(lexer.ilk_hata(metin_hata.tokenlar).deger, "metin")
yazdır json.yaz(lexer.hata_degerleri(metin_hata.tokenlar))

turkce_token olsun lexer.tokenlestir("çığ olsun 1\n")[0]
turkce_aralik olsun lexer.token_araligi(turkce_token)
yazdır lexer.token_uzunlugu(turkce_token)
yazdır turkce_aralik.satir
yazdır turkce_aralik.baslangic_sutun
yazdır turkce_aralik.bitis_sutun
yazdır turkce_aralik.uzunluk

araliklar olsun lexer.token_araliklari(lexer.tokenlestir("a olsun 1\n"))
yazdır uzunluk(araliklar)
yazdır araliklar[1].baslangic_sutun
yazdır araliklar[1].bitis_sutun

uyumsuz olsun lexer.ozetle("x\n")
uyumsuz.ir_sozlesmesi = "orhun-lexer-ir-v0"
yazdır lexer.ir_uyumlu_mu(uyumsuz)
yazdır metin.icerir(lexer.ir_dogrula(uyumsuz).hata, "beklenen")

bozuk_sayi olsun lexer.ozetle("x\n")
bozuk_sayi.token_sayisi = bozuk_sayi.token_sayisi + 1
yazdır lexer.ir_gecerli_mi(bozuk_sayi)
yazdır metin.icerir(lexer.ir_dogrula(bozuk_sayi).hata, "token_sayisi")

bozuk_son olsun {"ir_sozlesmesi": lexer.ir_sozlesmesi, "hata_sayisi": 0, "token_sayisi": 1, "tokenlar": [lexer.token("KIMLIK", "x", 1, 1)]}
yazdır lexer.ir_gecerli_mi(bozuk_son)
yazdır metin.icerir(lexer.ir_dogrula(bozuk_son).hata, "bitmeli")

bozuk_konum olsun {"ir_sozlesmesi": lexer.ir_sozlesmesi, "hata_sayisi": 0, "token_sayisi": 1, "tokenlar": [lexer.token("DOSYA_SONU", "", 0, 1)]}
yazdır lexer.ir_gecerli_mi(bozuk_konum)
yazdır metin.icerir(lexer.ir_dogrula(bozuk_konum).hata, "satir")
