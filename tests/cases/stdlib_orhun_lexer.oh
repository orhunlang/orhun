lexer olsun dahil_et "orhun/lexer.oh"

kaynak olsun "işlev ana():\n    puan olsun 10.5\n    yazdır \"merhaba\"\n"
tokenlar olsun lexer.tokenlestir(kaynak)

yazdır lexer.surum
yazdır uzunluk(tokenlar)
yazdır metin.birlestir(lexer.turleri(tokenlar), "|")
yazdır tokenlar[0].tur + ":" + tokenlar[0].deger
yazdır tokenlar[7].tur + ":" + tokenlar[7].deger
yazdır tokenlar[9].tur + ":" + tokenlar[9].deger
yazdır tokenlar[12].tur + ":" + tokenlar[12].deger
yazdır tokenlar[14].tur + ":" + tokenlar[14].deger

yorumlu olsun lexer.tokenlestir("# yorum\nx olsun 1\n")
yazdır yorumlu[0].tur + ":" + yorumlu[0].deger
yazdır yorumlu[1].tur + ":" + yorumlu[1].deger

girinti_hata olsun lexer.tokenlestir("eğer doğru ise:\n  yazdır 1\n yazdır 2\n")
yazdır lexer.hata_var_mi(girinti_hata)
yazdır metin.icerir(lexer.ilk_hata(girinti_hata).deger, "girinti")

metin_hata olsun lexer.tokenlestir("yazdır \"acik\n")
yazdır lexer.hata_var_mi(metin_hata)
yazdır metin.icerir(lexer.ilk_hata(metin_hata).deger, "metin")
