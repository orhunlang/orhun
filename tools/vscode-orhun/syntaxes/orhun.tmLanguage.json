{
  "name": "Orhun",
  "scopeName": "source.orhun",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.orhun",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.orhun",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.orhun",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.orhun",
              "match": "\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.orhun",
          "match": "\\b(eÄer|ise|deÄilse|sÃžrece|tekrarla|kez|her|deneme|yakala|kÄąr|devam)\\b"
        },
        {
          "name": "keyword.declaration.orhun",
          "match": "\\b(olsun|iÅlev|dÃķndÃžr|tip|yeni|dahil_et|dÄąÅ_iÅlev|dis_islev)\\b"
        },
        {
          "name": "constant.language.orhun",
          "match": "\\b(doÄru|yanlÄąÅ|benim|ust|iÃ§in|iÃ§inde|sor|yazdÄąr)\\b"
        },
        {
          "name": "keyword.operator.logical.orhun",
          "match": "\\b(eÅit|eÅit_deÄil|bÃžyÃžk|kÃžÃ§Ãžk|ve|veya|deÄil)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.orhun",
          "match": "\\b(yaz|yazdÄąr|sor|oku|aralik|aralÄąk|ilk|son|bos_mu|boÅ_mu|dolu_mu|uzunluk|metne_cevir|sayiya_cevir|bekle|token_araligi|token_araliklari|token_uzunlugu|ifade_satir_araligi|ifade_satir_araliklari|tum_ifade_satir_araliklari|ifade_derinligi|tum_ifade_derinligi|ifade_turleri|ifade_sayisi|ifade_turu_sayisi|ifade_turu_var_mi|ifade_agaci_ozeti|komut_satir_araligi|komut_satir_araliklari|tum_komut_satir_araliklari|komut_derinligi|tum_komut_derinligi|komut_turleri|komut_sayisi|komut_turu_sayisi|komut_turu_var_mi|komut_agaci_ozeti|ir_uyumlu_mu|ir_ozeti|hata_tanisi|hata_tanilari|tani_listesi_bicimlendir|tani_listesi_kaynak_bicimlendir|tani_listesi_seviyeleri|tani_listesi_seviye_sayisi|tani_listesi_seviyeye_gore_filtrele|tani_listesi_ozeti|dugumleri_duzlestir|dugum_turlerini_duzlestir|dugumleri_filtrele|dugum_turu_var_mi|dugum_derinligi|dugum_turu_sayisi|dugum_ozeti)\\b"
        },
        {
          "name": "support.module.orhun",
          "match": "\\b(json|metin|dosya|regex|gorev|veritabani)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.orhun",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
