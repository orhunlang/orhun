{
  "name": "Orhun",
  "scopeName": "source.orhun",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.orhun",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.orhun",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.orhun",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.orhun",
              "match": "\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.orhun",
          "match": "\\b(eğer|ise|değilse|sürece|tekrarla|kez|her|deneme|yakala|kır|devam)\\b"
        },
        {
          "name": "keyword.declaration.orhun",
          "match": "\\b(olsun|işlev|döndür|tip|yeni|dahil_et|dış_işlev|dis_islev)\\b"
        },
        {
          "name": "constant.language.orhun",
          "match": "\\b(doğru|yanlış|benim|ust|için|içinde|sor|yazdır)\\b"
        },
        {
          "name": "keyword.operator.logical.orhun",
          "match": "\\b(eşit|eşit_değil|büyük|küçük|ve|veya|değil)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.orhun",
          "match": "\\b(yaz|yazdır|sor|oku|aralik|aralık|ilk|son|bos_mu|boş_mu|dolu_mu|uzunluk|metne_cevir|sayiya_cevir|bekle|token_araligi|token_araliklari|token_uzunlugu|ifade_satir_araligi|ifade_satir_araliklari|komut_satir_araligi|komut_satir_araliklari|tum_komut_satir_araliklari|hata_tanisi|hata_tanilari|tani_listesi_bicimlendir|tani_listesi_kaynak_bicimlendir|dugumleri_duzlestir|dugum_turlerini_duzlestir|dugumleri_filtrele|dugum_turu_var_mi|dugum_derinligi|dugum_turu_sayisi|dugum_ozeti)\\b"
        },
        {
          "name": "support.module.orhun",
          "match": "\\b(json|metin|dosya|regex|gorev|veritabani)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.orhun",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.orhun",
          "match": "[+\\-*/=.:,\\[\\](){}]"
        }
      ]
    }
  }
}
