{
  "name": "Orhun",
  "scopeName": "source.orhun",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.orhun",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.orhun",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.orhun",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.orhun",
              "match": "\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.orhun",
          "match": "\\b(eﾄ歹r|ise|deﾄ殃lse|sﾃｼrece|tekrarla|kez|her|deneme|yakala|kﾄｱr|devam)\\b"
        },
        {
          "name": "keyword.declaration.orhun",
          "match": "\\b(olsun|iﾅ殕ev|dﾃｶndﾃｼr|tip|yeni|dahil_et|dﾄｱﾅ歙iﾅ殕ev|dis_islev)\\b"
        },
        {
          "name": "constant.language.orhun",
          "match": "\\b(doﾄ殲u|yanlﾄｱﾅ毫benim|ust|iﾃｧin|iﾃｧinde|sor|yazdﾄｱr)\\b"
        },
        {
          "name": "keyword.operator.logical.orhun",
          "match": "\\b(eﾅ殃t|eﾅ殃t_deﾄ殃l|bﾃｼyﾃｼk|kﾃｼﾃｧﾃｼk|ve|veya|deﾄ殃l)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.orhun",
          "match": "\\b(yaz|yazdﾄｱr|sor|oku|aralik|aralﾄｱk|ilk|son|bos_mu|boﾅ歙mu|dolu_mu|uzunluk|metne_cevir|sayiya_cevir|bekle|token_araligi|token_araliklari|token_uzunlugu|ifade_satir_araligi|ifade_satir_araliklari|tum_ifade_satir_araliklari|ifade_derinligi|tum_ifade_derinligi|ifade_turleri|ifade_sayisi|ifade_turu_sayisi|ifade_turu_var_mi|ifade_agaci_ozeti|komut_satir_araligi|komut_satir_araliklari|tum_komut_satir_araliklari|komut_derinligi|tum_komut_derinligi|komut_turleri|komut_sayisi|komut_turu_sayisi|komut_turu_var_mi|komut_agaci_ozeti|ir_uyumlu_mu|ir_dogrula|ir_gecerli_mi|ir_ozeti|hata_tanisi|hata_tanilari|tani_listesi_bicimlendir|tani_listesi_kaynak_bicimlendir|tani_listesi_seviyeleri|tani_listesi_seviye_sayisi|tani_listesi_seviyeye_gore_filtrele|tani_listesi_ozeti|dugumleri_duzlestir|dugum_turlerini_duzlestir|dugumleri_filtrele|dugum_turu_var_mi|dugum_derinligi|dugum_turu_sayisi|dugum_ozeti)\\b"
        },
        {
          "name": "support.module.orhun",
          "match": "\\b(json|metin|dosya|regex|gorev|veritabani)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.orhun",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.orhun",
          "match": "[+\\-*/=.:,\\[\\](){}]"
        }
      ]
    }
  }
}
