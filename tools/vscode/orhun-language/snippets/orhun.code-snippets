      "    yazdır ${2:hata}"
    ],
    "description": "deneme/yakala bloğu"
  },
  "Liste Ureteci": {
    "prefix": "uretec",
    "body": [
      "${1:kareler} olsun [ ${2:x * x} için ${3:x} içinde ${4:sayilar} ]"
    ],
    "description": "liste üreteci"
  }
