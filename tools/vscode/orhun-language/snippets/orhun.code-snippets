{
  "Eger Blok": {
    "prefix": "eger",
    "body": [
      "eğer ${1:kosul} ise:",
      "    ${2:yazdır \"Dogru\"}"
    ],
    "description": "if benzeri eğer bloğu"
  },
  "Eger Degilse Blok": {
    "prefix": "eger2",
    "body": [
      "eğer ${1:kosul} ise:",
      "    ${2:yazdır \"Dogru\"}",
      "değilse:",
      "    ${3:yazdır \"Yanlis\"}"
    ],
    "description": "if/else benzeri eğer-değilse bloğu"
  },
  "Surece Dongusu": {
    "prefix": "surece",
    "body": [
      "sürece ${1:kosul}:",
      "    ${2:yazdır \"dongu\"}"
    ],
    "description": "while benzeri sürece döngüsü"
  },
  "Tekrarla Dongusu": {
    "prefix": "tekrarla",
    "body": [
      "tekrarla ${1:3} kez",
      "    ${2:yazdır \"tekrar\"}"
    ],
    "description": "tekrarla kez döngüsü"
  },
  "Islev Tanimi": {
    "prefix": "islev",
    "body": [
      "işlev ${1:ad}(${2:param}):",
