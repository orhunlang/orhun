{
  "name": "orhun-language",
  "displayName": "Orhun Language",
  "description": "Syntax highlighting and snippets for Orhun (.oh)",
  "version": "0.1.0",
  "publisher": "orhun",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "orhun",
        "aliases": [
          "Orhun",
          "orhun"
        ],
        "extensions": [
          ".oh"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "orhun",
        "scopeName": "source.orhun",
        "path": "./syntaxes/orhun.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "orhun",
        "path": "./snippets/orhun.code-snippets"
      }
    ]
  }
}
